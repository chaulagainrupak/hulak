---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LetterOutline } from "../components/AirMailBorder";
---

<BaseLayout title="Privacy Policy - Hulak">
  <main class="min-h-screen px-6 py-24 flex justify-center items-center">
    <div class="w-full max-w-3xl">
      <LetterOutline strokeWidth={16}>
        <div class="p-12">
          <h1 class="text-4xl font-semibold tracking-tight text-[var(--onyx)]">
            Privacy Policy
          </h1>

          <p class="text-sm mt-3 text-[var(--blue-energy)] font-medium">
            Effective: May 18, 2026
          </p>

          <div class="mt-12 space-y-10 text-base leading-7 text-[var(--onyx)]/85">
            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Overview</h2>
              <p class="leading-relaxed">
                Hulak is built on a foundation of privacy. We collect only what is necessary to operate the service. We believe you have the right to know exactly what we collect, how we use it, and how to control it. This privacy policy explains everything clearly—no legal jargon, just honesty.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Data We Collect</h2>
              <p class="leading-relaxed mb-4">When you use Hulak, we collect:</p>
              <ul class="mt-4 space-y-2 pl-6">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--red-stamp)] font-bold mt-1">•</span>
                  <span><strong>Your name</strong> — required so others know who wrote the letter</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--red-stamp)] font-bold mt-1">•</span>
                  <span><strong>Letter content</strong> — the text, formatting, fonts, and decorative stamps you create</span>
                </li>
              </ul>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">What We Don't Collect</h2>
              <p class="leading-relaxed mb-4">We specifically do NOT collect:</p>
              <ul class="mt-4 space-y-2 pl-6">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>Cookies</strong> — no persistent cookies or tracking cookies</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>IP addresses</strong> — we don't log or store your IP</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>Location data</strong> — we don't track where you are</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>Browser fingerprints</strong> — no tracking via device info</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>Behavioral data</strong> — we don't profile your interests or habits</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span><strong>Ads or third-party trackers</strong> — we don't sell your data or show you targeted ads</span>
                </li>
              </ul>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Analytics</h2>
              <p class="leading-relaxed">
                We use <span class="text-[var(--blue-energy)] font-semibold bg-[var(--wheat)]/50 px-2 py-1 rounded">Umami Analytics</span>, a privacy-first analytics tool. It tells us:
              </p>
              <ul class="mt-4 space-y-1 pl-6 list-disc">
                <li>How many people visit Hulak</li>
                <li>Which pages are most popular</li>
                <li>Basic traffic patterns</li>
              </ul>
              <p class="leading-relaxed mt-4">
                Umami does <strong>not</strong> use cookies, doesn't track individuals across sites, and doesn't create user profiles. It's just aggregate, anonymized data.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">How We Use Your Data</h2>
              <p class="leading-relaxed mb-4">Your data is used only for:</p>
              <ul class="mt-4 space-y-1 pl-6 list-disc">
                <li>Displaying your letter when shared via a unique link</li>
                <li>Investigating abuse reports or suspected CSAM</li>
                <li>Communicating with you if you report an issue</li>
              </ul>
              <p class="leading-relaxed mt-4">
                We never sell your data, share it with advertisers, or use it for purposes you haven't agreed to.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Letter Privacy & Moderation</h2>
              <p class="leading-relaxed mb-4">
                Letters are private communications intended for two people. Only someone with the unique link can view your letter. We do not:
              </p>
              <ul class="mt-4 space-y-2 pl-6">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span>Read your letters</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span>Index or search letters</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--blue-energy)] font-bold mt-1">✓</span>
                  <span>Share letters with anyone</span>
                </li>
              </ul>
              <p class="leading-relaxed mt-4"><strong>Exception:</strong> We only access letters to investigate reports of abuse or to protect against CSAM (child sexual abuse material). Otherwise, your letter is completely private.</p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Data Security</h2>
              <p class="leading-relaxed">
                Your letters are stored securely on our server. While we don't use encryption, the privacy of your letter is protected by the fact that it can only be accessed via a unique, unguessable link. This is designed so only you and the intended recipient can view it. If you have sensitive information, please be mindful about what you share.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Your Rights & Data Control</h2>
              <p class="leading-relaxed mb-4">Currently, since we don't have user accounts yet, you can:</p>
              <ul class="mt-4 space-y-2 pl-6">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--red-stamp)] font-bold mt-1">•</span>
                  <span><strong>Request letter deletion</strong> — email us with the letter link and we'll remove it</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--red-stamp)] font-bold mt-1">•</span>
                  <span><strong>Request your data</strong> — contact support and we'll provide all letters you created</span>
                </li>
              </ul>
              <p class="leading-relaxed mt-4">When we launch user accounts, you'll have direct control to manage and delete your own letters.</p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Data Retention</h2>
              <p class="leading-relaxed">
                Letters remain live indefinitely unless you request deletion via <a href="mailto:support@hulak.app" class="text-[var(--blue-energy)] hover:underline font-medium">support@hulak.app</a>. We will delete letters promptly upon request. Anonymous analytics data (from Umami) is aggregated and not linked to you personally.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Third-Party Services</h2>
              <p class="leading-relaxed">
                Hulak is self-hosted and doesn't rely on external tracking services. We don't use Google Analytics, Facebook Pixel, or similar trackers. We use Umami (privacy-first) for analytics only.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Policy Updates</h2>
              <p class="leading-relaxed">
                We may update this policy if our practices change. If changes affect your privacy significantly, we'll notify you. Your continued use of Hulak means you accept any updates.
              </p>
            </section>

            <section class="pt-4 border-t-2 border-[var(--wheat)]">
              <h2 class="text-xl font-semibold text-[var(--onyx)] mb-3">Questions or Concerns?</h2>
              <p class="leading-relaxed">
                We believe in transparency. If you have any questions about how we handle your data, or if you want to exercise any of your rights, contact us at <a href="mailto:support@hulak.app" class="text-[var(--blue-energy)] hover:underline font-medium">support@hulak.app</a>. We'll respond within 24 hours.
              </p>
            </section>
          </div>
        </div>
      </LetterOutline>
    </div>
  </main>
</BaseLayout>

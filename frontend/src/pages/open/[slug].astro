---
export const prerender = false;

import { LetterOutline } from "../../components/AirMailBorder";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EnvelopePreview from "../../components/EnvelopeTheme";
import LetterViewer from "../../components/LetterViewer";
import { API_URL } from "../../utilities/constants";
import { faPaperPlane } from "@fortawesome/free-solid-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";

const slug = Astro.params.slug;

let letter = null;
let error = false;

try {
  const response = await fetch(`${API_URL}/letter/${slug}`);

  if (!response.ok) {
    error = true;
  } else {
    const data = await response.json();
    letter = data?.letter ?? null;

    if (!letter) error = true;
  }
} catch {
  error = true;
}

const ogTitle = letter
  ? `A letter for ${letter.receiver_name}`
  : "Letter not found";

const ogDesc = letter
  ? `${letter.sender_name} sent you a ${letter.occasion?.toLowerCase()} letter on Hulak.`
  : "This letter does not exist or has been removed.";

const ogImage = `${API_URL}/ogp/${slug}`;
const pageUrl = `https://hulak.app/letter/${slug}`;
---

<BaseLayout
  title={ogTitle}
  description={ogDesc}
  ogImage={ogImage}
  ogUrl={pageUrl}
>
  <div
    class="min-h-screen px-4 py-10 lg:px-32 flex flex-col items-center gap-6"
  >
    {
      error || !letter ? (
        <div class="w-full max-w-6xl flex items-center justify-center min-h-[65vh] bg-[var(--wheat)] rounded-2xl border border-black/10">
          <LetterOutline paperClassName="shadow-sm">
            <div class="text-center w-full max-w-2xl text-[var(--onyx)] p-6 sm:p-10">
              <div class="mb-6">
                <div class="text-3xl sm:text-4xl font-semibold underline mb-2">
                  Letter not found
                </div>

                <div class="text-sm sm:text-base text-gray-500 italic">
                  /undelivered mail — postal archive error/
                </div>
              </div>

              <div class="text-left text-gray-800 space-y-4 text-sm sm:text-base leading-relaxed mb-8">
                <p>
                  This letter appears to have gone missing somewhere between
                  dispatch and delivery. Our postal system has no record of its
                  final destination.
                </p>

                <p>
                  It may have been misaddressed, delayed, or simply never placed
                  into circulation. In rare cases, letters like this are never
                  recovered.
                </p>

                <p>
                  But messages are never truly lost — they just wait for a
                  second chance to be sent again.
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a
                  href="/stamps"
                  data-umami-event="Error Page - Browse Stamps Link"
                  class=" outline outline-[var(--onyx)] shadow-lg flex items-center gap-2 mx-auto px-4 py-2 sm:px-6 sm:py-3   rounded-lg font-semibold text-sm sm:text-base hover:scale-105 hover:rotate-2 cursor-pointer transition"
                >
                  Browse Stamps
                </a>

                <a
                  href="/"
                  data-umami-event="Error Page - Send New Letter Link"
                  class="shadow-lg flex items-center gap-2 mx-auto px-4 py-2 sm:px-6 sm:py-3 bg-[var(--blue-energy)] text-white rounded-lg font-semibold text-sm sm:text-base hover:scale-105 hover:rotate-2 cursor-pointer transition"
                >
                  Send a Letter
                  <FontAwesomeIcon icon={faPaperPlane} className="w-4 h-4" />
                </a>
              </div>
            </div>
          </LetterOutline>
        </div>
      ) : (
        <>
          <div class="w-full max-w-6xl">
            <LetterOutline
              client:load
              paperClassName="aspect-[2.4/1] rounded-xl overflow-hidden"
            >
              <EnvelopePreview
                client:load
                senderName={letter.sender_name}
                receiverName={letter.receiver_name}
                occasion={letter.occasion}
                customOccasionLabel={letter.custom_occasion_label}
                stampUrl={letter.stamp_url ?? ""}
                stampLabel={letter.stamp_label ?? ""}
              />
            </LetterOutline>
          </div>

          <div class="w-full max-w-6xl bg-white border border-black/[0.07] rounded-2xl overflow-hidden shadow-sm">
            <LetterOutline
              client:load
              paperClassName="p-5 lg:p-8 bg-[var(--wheat)] rounded-xl"
            >
              <LetterViewer
                client:only="react"
                content={letter.content ?? ""}
              />
            </LetterOutline>
          </div>
        </>
      )
    }

    <div class="w-full max-w-6xl flex justify-center pt-2">
      <a
        href="/"
        class="text-xs text-[var(--onyx)] opacity-60 hover:opacity-100 transition"
      >
        Send your own letter at <span class="font-semibold">hulak.app</span>
      </a>
    </div>
  </div>
</BaseLayout>
